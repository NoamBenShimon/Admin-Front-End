# API Configuration
NODE_ENV=development
# Environment

SESSION_SECRET=change-this-to-a-random-secret-in-production
# Session Configuration

NEXT_PUBLIC_API_URL=http://localhost:3000/api
# For maximum security, client should call Next.js API routes instead of backend directly
# Public API URL - used by client-side code (if needed)

API_URL=http://localhost:8000
# Backend API base URL - used by Next.js API routes for server-side calls

