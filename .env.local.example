# =============================================================================
# Admin Front-End environment
# Copy to `.env.local` and adjust for your setup.
# =============================================================================

NODE_ENV=development

# --- Data source ------------------------------------------------------------
# When "true" (the default) the whole admin panel runs on the in-memory mock
# store and needs no backend. Set to "false" to use the live backend; endpoints
# the backend hasn't implemented yet fall back to mock data automatically.
# Demo admin login (mock mode): username "admin", password "1234".
NEXT_PUBLIC_USE_MOCKS=true

# --- API wiring -------------------------------------------------------------
# Client calls the same-origin Next.js API routes. Leave as "/api" unless you
# are serving the API routes from a different origin.
NEXT_PUBLIC_API_URL=/api

# Backend base URL, used server-side by the Next.js API routes (never exposed to
# the browser). The Go backend listens on :8080 by default.
API_URL=http://localhost:8080

# --- Misc -------------------------------------------------------------------
SESSION_SECRET=change-this-to-a-random-secret-in-production
